WOLFIE_ENVIRONMENT=SIMULATED_LIVE_MCP_LOCAL
WOLFIE_STARTING_CASH=25000
WOLFIE_SQLITE_PATH=data/wolfie.sqlite3
WOLFIE_API_PORT=8000
WOLFIE_WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Wolfie public site waitlist email provider.
# RESEND_API_KEY must be set in the deployment environment.
# WOLFIE_WAITLIST_FROM must be a verified sender for the Resend account.
# WOLFIE_WAITLIST_XLSX_PATH defaults to data/wolfie-waitlist.xlsx.
# Set WOLFIE_WAITLIST_EMAIL_MODE=file for local verification without Resend.
# BLOB_READ_WRITE_TOKEN is created when the private Vercel Blob store is connected.
# Set WOLFIE_WAITLIST_DURABLE_REQUIRED=true in production so /tmp is never the only record.
RESEND_API_KEY=
WOLFIE_WAITLIST_FROM=
WOLFIE_WAITLIST_TO=support@wolfietrade.com
WOLFIE_WAITLIST_XLSX_PATH=
WOLFIE_WAITLIST_EMAIL_MODE=
WOLFIE_WAITLIST_EMAIL_PATH=
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
WOLFIE_WAITLIST_DURABLE_REQUIRED=
